FROM --platform=linux/amd64 ghcr.io/cross-rs/x86_64-unknown-linux-gnu:main@sha256:24a06c5c6b54a56bd203207ec6f5af85df5855701f51db42a291c27f17a71439

RUN DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get -y --no-install-recommends install \
    libpango-1.0-0 \
    libpango1.0-dev \
    libgtk-3-dev
