FROM --platform=linux/amd64 ghcr.io/cross-rs/x86_64-unknown-linux-gnu:main@sha256:3ef2fcc0c666194a7f1ae498afa552428e55cc24e2e2616a4f6d2163069c7df6

RUN DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get -y --no-install-recommends install \
    libpango-1.0-0 \
    libpango1.0-dev \
    libgtk-3-dev
