FROM --platform=linux/amd64 ghcr.io/cross-rs/x86_64-unknown-linux-gnu:main@sha256:dc141363174ec8135dac1e4dc13f14edf619bff823824e8e2295a862f311d83b

RUN DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get -y --no-install-recommends install \
    libpango-1.0-0 \
    libpango1.0-dev \
    libgtk-3-dev
